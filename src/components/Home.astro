---
import Base from '../layouts/Base.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import Section from './Section.astro';
import { site, t, otherLocale, type Locale } from '../content/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const other = otherLocale(locale);
---

<Base locale={locale}>
  <Header locale={locale} />

  <main id="main">
    <section class="hero reveal" aria-label={site.name}>
      <div class="wrap">
        <p class="label kicker">{t(site.hero.kicker, locale)}</p>
        <h1>{site.name}<span class="dot">.</span></h1>
        <p class="hero-lead">{t(site.hero.lead, locale)}</p>
        <p class="hero-belief">{t(site.hero.belief, locale)}</p>
        <div class="hero-anchors">
          {
            site.hero.anchors.map((anchor) => (
              <div class="anchor">
                <span class="label">{t(anchor.label, locale)}</span>
                <strong>{t(anchor.value, locale)}</strong>
                <span>{t(anchor.sub, locale)}</span>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <Section
      id={site.about.id}
      num="01"
      title={t(site.about.title, locale)}
      whisper={t(site.about.whisper, locale)}
      whisperLang={other}
    >
      {site.about.paragraphs.map((p) => <p class="section-intro">{t(p, locale)}</p>)}
    </Section>

    <Section
      id={site.education.id}
      num="02"
      title={t(site.education.title, locale)}
      whisper={t(site.education.whisper, locale)}
      whisperLang={other}
    >
      <p class="section-intro">{t(site.education.intro, locale)}</p>
      <ol class="timeline">
        {
          site.education.entries.map((entry) => (
            <li>
              <span class="when">{t(entry.time, locale)}</span>
              <div>
                <h3>{t(entry.degree, locale)}</h3>
                <span class="where">{t(entry.school, locale)}</span>
                <p class="what">{t(entry.detail, locale)}</p>
                {'link' in entry && entry.link && (
                  <a class="more" href={entry.link.href} rel="noopener">
                    {t(entry.link.label, locale)} ↗
                  </a>
                )}
              </div>
            </li>
          ))
        }
      </ol>
    </Section>

    <Section
      id={site.work.id}
      num="03"
      title={t(site.work.title, locale)}
      whisper={t(site.work.whisper, locale)}
      whisperLang={other}
    >
      <p class="section-intro">{t(site.work.intro, locale)}</p>
      <ol class="timeline">
        {
          site.work.entries.map((entry) => (
            <li>
              <span class="when">{t(entry.time, locale)}</span>
              <div>
                <h3>{t(entry.role, locale)}</h3>
                <span class="where">{t(entry.org, locale)}</span>
                <p class="what">{t(entry.detail, locale)}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </Section>

    <Section
      id={site.credentials.id}
      num="04"
      title={t(site.credentials.title, locale)}
      whisper={t(site.credentials.whisper, locale)}
      whisperLang={other}
    >
      <p class="section-intro">{t(site.credentials.intro, locale)}</p>
      <ul class="credentials">
        {
          site.credentials.items.map((item) => (
            <li>
              <div>
                <span class="cred-name">{t(item.name, locale)}</span>
                <span class="cred-issuer">{t(item.issuer, locale)}</span>
              </div>
              {item.href && (
                <a class="cred-link" href={item.href} rel="noopener">
                  {t(site.credentials.verifyLabel, locale)} ↗
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </Section>

    <Section
      id={site.craft.id}
      num="05"
      title={t(site.craft.title, locale)}
      whisper={t(site.craft.whisper, locale)}
      whisperLang={other}
    >
      <p class="section-intro">{t(site.craft.intro, locale)}</p>
      <div class="quiet-grid">
        {
          site.craft.items.map((item) => (
            <div class="cell">
              <h3>{t(item.name, locale)}</h3>
              <p>{t(item.detail, locale)}</p>
            </div>
          ))
        }
      </div>
      <div class="craft-links">
        {
          site.craft.links.map((link) => (
            <a href={link.href} rel="noopener">
              {t(link.label, locale)} ↗
            </a>
          ))
        }
      </div>
    </Section>

    <Section
      id={site.principles.id}
      num="06"
      title={t(site.principles.title, locale)}
      whisper={t(site.principles.whisper, locale)}
      whisperLang={other}
    >
      <ol class="principles">
        {
          site.principles.items.map((item) => (
            <li>
              <div>
                <h3>{t(item.statement, locale)}</h3>
                <p>{t(item.detail, locale)}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </Section>

    <Section
      id={site.offClock.id}
      num="07"
      title={t(site.offClock.title, locale)}
      whisper={t(site.offClock.whisper, locale)}
      whisperLang={other}
    >
      <p class="section-intro">{t(site.offClock.intro, locale)}</p>
      <div class="quiet-grid">
        {
          site.offClock.items.map((item) => (
            <div class="cell">
              <h3>{t(item.name, locale)}</h3>
              <p>{t(item.detail, locale)}</p>
              {'link' in item && item.link && (
                <a class="more" href={item.link.href} rel="noopener">
                  {t(item.link.label, locale)} ↗
                </a>
              )}
            </div>
          ))
        }
      </div>
    </Section>
  </main>

  <Footer locale={locale} />
</Base>
