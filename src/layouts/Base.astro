---
import '@fontsource-variable/literata/opsz.css';
import '@fontsource-variable/literata/opsz-italic.css';
import '@fontsource/be-vietnam-pro/400.css';
import '@fontsource/be-vietnam-pro/500.css';
import '@fontsource/be-vietnam-pro/600.css';
import '../styles/global.css';
import { site, t, type Locale } from '../content/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const urlFor = (l: Locale) => (l === 'vi' ? site.url : `${site.url}en/`);
const canonical = urlFor(locale);
const ogImage = `${site.url}og.png`;
const ogLocale = locale === 'vi' ? 'vi_VN' : 'en_US';
const ogLocaleAlt = locale === 'vi' ? 'en_US' : 'vi_VN';
const skipLabel = locale === 'vi' ? 'Bỏ qua phần điều hướng' : 'Skip to content';
---

<html lang={locale} class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{t(site.title, locale)}</title>
    <meta name="description" content={t(site.description, locale)} />
    <meta name="author" content={site.name} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="vi" href={urlFor('vi')} />
    <link rel="alternate" hreflang="en" href={urlFor('en')} />
    <link rel="alternate" hreflang="x-default" href={urlFor('vi')} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="sitemap" href={`${base}sitemap-index.xml`} />

    <meta property="og:type" content="profile" />
    <meta property="og:title" content={t(site.title, locale)} />
    <meta property="og:description" content={t(site.description, locale)} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta property="og:site_name" content={site.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={t(site.title, locale)} />
    <meta name="twitter:description" content={t(site.description, locale)} />
    <meta name="twitter:image" content={ogImage} />

    <script is:inline>
      document.documentElement.classList.remove('no-js');
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">{skipLabel}</a>
    <slot />

    <script is:inline>
      (function () {
        var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var items = document.querySelectorAll('.reveal');
        if (reduced || !('IntersectionObserver' in window)) {
          items.forEach(function (el) {
            el.classList.add('is-visible');
          });
          return;
        }
        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.05 }
        );
        items.forEach(function (el) {
          observer.observe(el);
        });
      })();
    </script>
  </body>
</html>
